# ── Model configuration ──────────────────────────────────────────────────────
# Text model used for persona generation (Phase 1)
TEXT_MODEL=llama3.3:70b

# Vision model used for image annotation (Phase 2)
# Paper results used Qwen3-VL:8B
VISION_MODEL=qwen3-vl:8b

# Ollama server endpoint (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# ── Concurrency ──────────────────────────────────────────────────────────────
# Phase 1: number of simultaneous persona graph invocations
MAX_CONCURRENT=5

# Phase 2: must match OLLAMA_NUM_PARALLEL on the Ollama server
# Tuning guide:
#   20 GB GPU  → 1-2 slots (with FLASH_ATTENTION + q8_0 KV cache)
#   40 GB GPU  → 3-4 slots
#   95 GB GPU  → 6-8 slots
ANNOTATION_MAX_CONCURRENT=1

# ── Pipeline parameters ──────────────────────────────────────────────────────
MAX_RETRIES=3
RANDOM_SEED=42

# Context window for vision model calls (4096 is sufficient for ~200-token JSON outputs)
NUM_CTX=4096

# Hard timeout per vision model call (seconds)
LLM_TIMEOUT_S=360

# ── Output paths ─────────────────────────────────────────────────────────────
OUTPUT_DIR=outputs

# ── Dataset paths ─────────────────────────────────────────────────────────────
# Directory containing the 5,000 PerceptSent JPEG images (download separately)
# See README.md § Data Setup for download instructions
IMAGE_DIR=data/raw_images
